config.ini
match_state.json
match_data.db
match_data.db-shm
match_data.db-wal
__pycache__/
*.pyc
*.log
.DS_Store

# Runtime-generated files
season_stats_cache.json

# YouTube OAuth — NEVER commit these. yt_credentials.json is your Google OAuth client
# secret; yt_token.json is the authorised access/refresh token. Either one leaking lets
# someone act as your channel.
yt_credentials.json
yt_token.json

# Club-specific asset folders (different for every club)
sponsors/
headshots/
logos/
socials/

# Match simulator output (rehearsal only)
sim_pcs_output/

# Manual scoring session (live match data, per-day)
manual_scoring.json

# NV Play bridge (remote scorer machine): mirrored PCS files + the bridge's own config
# (holds a local folder path and a secret token — machine-specific, never shared)
.pcs_bridge_cache/
bridge_config.ini

